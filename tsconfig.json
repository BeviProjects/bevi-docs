{
	"compilerOptions": {
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./src/*"],
			"@bevi-icon/*": ["./src/app/(main)/bevi-icon/*"],
			"@bevi-logo/*": ["./src/app/(main)/bevi-logo/*"],
			"@component/*": ["./src/components/*"],
			"@config/*": ["./src/config/*"],
			"@context/*": ["./src/contexts/*"],
			"@hook/*": ["./src/hooks/*"],
			"@util/*": ["./src/utils/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.mts"
	],
	"exclude": ["node_modules"]
}
